# --- met.no ---
# Required by met.no APIs: a User-Agent identifying your app + contact.
# This is a hard requirement; requests without it get 403.
METNO_USER_AGENT=ferry-delay-predictor/0.1 kristoffer@cmdhub.ai

# Frost (historical observations) only. Free registration: https://frost.met.no/auth/requestCredentials.html
# Leave blank for now — Phase 1 real-time collection does not need it.
FROST_CLIENT_ID=

# --- Entur (ferry real-time) ---
# Any stable identifying string. https://developer.entur.org/
ET_CLIENT_NAME=kristoffer-ferry-delay-predictor

# --- Route configuration ---
# Fill STOP_PLACE_ID by running:  python -m ferrydelay.lookup stop "Halhjem"
# Default target route: Halhjem–Sandvikvåg (E39, across Bjørnafjorden — very weather-exposed).
ROUTE_NAME=Halhjem-Sandvikvag
STOP_PLACE_ID=
# Keep only sailings toward this destination (case-insensitive substring).
# Halhjem quay also serves Våge (line 1021); we only want Sandvikvåg (line 1018).
DESTINATION_FILTER=Sandvikvåg

# Mid-crossing coordinates (used for wave/ocean forecast — set to open water, not the quay).
ROUTE_LAT=60.075
ROUTE_LON=5.360

# Optional: nearest met.no Frost weather station (find with: python -m ferrydelay.lookup station)
FROST_SOURCE_ID=

# SQLite database path
DB_PATH=data/ferry.db
